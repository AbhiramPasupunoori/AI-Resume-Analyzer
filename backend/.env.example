DJANGO_SECRET_KEY=your-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# DJANGO_SECURE_HSTS_SECONDS=31536000

# Local Docker PostgreSQL settings. In production, set DATABASE_URL to the
# pooled PostgreSQL connection string supplied by Neon.
DATABASE_NAME=resume_analyzer
DATABASE_USER=resume_user
DATABASE_PASSWORD=resume_password
DATABASE_HOST=localhost
DATABASE_PORT=5432
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require

FRONTEND_URL=http://localhost:5173

SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2
